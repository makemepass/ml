import matplotlib.pyplot as plt
from sklearn.metrics import confusion_matrix, ConfusionMatrixDisplay
from sklearn.feature_extraction.text import CountVectorizer
from sklearn.naive_bayes import MultinomialNB
from collections import Counter

texts = [
    "Win money now",
    "Claim free prize",
    "Limited time offer",
    "Exclusive deal just for you",
    "Hello how are you",
    "Let's meet tomorrow",
    "Are you available for a call",
    "Good morning have a nice day"
]

labels = [1, 1, 1, 1, 0, 0, 0, 0]

vectorizer = CountVectorizer()
X = vectorizer.fit_transform(texts)

model = MultinomialNB()
model.fit(X, labels)

y_pred = model.predict(X)

print("Predictions:\n")
for text, pred in zip(texts, y_pred):
    print(f"{text} -> {'Spam' if pred == 1 else 'Not Spam'}")

cm = confusion_matrix(labels, y_pred)

disp = ConfusionMatrixDisplay(
    confusion_matrix=cm,
    display_labels=["Not Spam", "Spam"]
)

disp.plot(cmap='Blues')
plt.title("Confusion Matrix")
plt.show()

spam_wc = [len(t.split()) for t, l in zip(texts, labels) if l == 1]
ham_wc = [len(t.split()) for t, l in zip(texts, labels) if l == 0]

plt.figure()
plt.boxplot([spam_wc, ham_wc], labels=["Spam", "Not Spam"])
plt.title("Word Count Comparison")
plt.ylabel("Number of Words")
plt.show()

all_words = " ".join(texts).lower().split()
word_counts = Counter(all_words)

common_words = word_counts.most_common(10)

words = [w for w, c in common_words]
counts = [c for w, c in common_words]

plt.figure()
plt.bar(words, counts)
plt.title("Top 10 Word Frequencies")
plt.xlabel("Words")
plt.ylabel("Frequency")
plt.xticks(rotation=45)
plt.show()

spam_count = labels.count(1)
not_spam_count = labels.count(0)

plt.figure()
plt.bar(["Spam", "Not Spam"], [spam_count, not_spam_count], color=["red", "green"])
plt.title("Spam vs Not Spam Count")
plt.ylabel("Number of Messages")
plt.show()
